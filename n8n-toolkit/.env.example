# payi-n8n-toolkit — environment variables
#
# Copy to .env (gitignored) or use 1Password CLI with a .env.op file.
# All values below are PLACEHOLDERS — replace before use.

# ── n8n connection ───────────────────────────────────────────────────────
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=PLACEHOLDER-N8N-API-KEY

# ── Pay-i connection ─────────────────────────────────────────────────────
PAYI_BASE_URL=https://api.pay-i.com
PAYI_API_KEY=PLACEHOLDER-PAYI-API-KEY

# ── Provider keys (only needed for `proxy` / `proxy_anthropic` builders) ──
# Chat model migrations inherit credentials from the source node;
# these are not usually required.
OPENAI_API_KEY=PLACEHOLDER-OPENAI-KEY
ANTHROPIC_API_KEY=PLACEHOLDER-ANTHROPIC-KEY
AZURE_OPENAI_API_KEY=PLACEHOLDER-AZURE-OPENAI-KEY

# ── AWS Bedrock (multi-field credential) ─────────────────────────────────
AWS_ACCESS_KEY_ID=PLACEHOLDER-AWS-ACCESS-KEY-ID
AWS_SECRET_ACCESS_KEY=PLACEHOLDER-AWS-SECRET-ACCESS-KEY
AWS_REGION=us-east-1

# ── Databricks (only used when migrator creates a payiDatabricksApi cred) ─
PAYI_DBX_PAT=PLACEHOLDER-DATABRICKS-PAT
PAYI_DBX_WORKSPACE_URL=https://YOUR-WORKSPACE.cloud.databricks.com
